# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your_search_key_here
AZURE_SEARCH_INDEX_NAME=tech-assist-kb

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/taai

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Confluence
CONFLUENCE_URL=https://macquarie.atlassian.net
CONFLUENCE_TOKEN=your_confluence_token
CONFLUENCE_SPACES=IT,TECHSUPPORT,INFOSEC

# SharePoint
SHAREPOINT_SITE_URL=https://macquarie.sharepoint.com/sites/TechAssist
SHAREPOINT_CLIENT_ID=your_client_id
SHAREPOINT_CLIENT_SECRET=your_client_secret

# ServiceNow
SERVICENOW_INSTANCE=macquarie
SERVICENOW_USER=your_snow_user
SERVICENOW_PASSWORD=your_snow_password

# Azure AD
AZURE_AD_TENANT_ID=your_tenant_id
AZURE_AD_CLIENT_ID=your_client_id
AZURE_AD_CLIENT_SECRET=your_client_secret

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your_key

# API Configuration
API_VERSION=v1
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_GLOBAL=10000

# Security
SECRET_KEY=your_secret_key_here_generate_with_openssl
ALLOWED_ORIGINS=https://macquarie.com,https://sharepoint.macquarie.com
